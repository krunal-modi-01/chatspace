# Copy to `.env.local` for local development (never commit real values).
# Points the typed REST client at the backend's /v1 base path.
VITE_API_BASE_URL=http://localhost:8000/v1

# Optional — overrides the derived `/v1/ws` WebSocket base (T33). If unset,
# it is derived from VITE_API_BASE_URL (scheme swapped http(s)->ws(s)).
# VITE_WS_BASE_URL=ws://localhost:8000/v1/ws
