# Copy to `.env` at the repo root to override docker-compose's local-dev
# defaults (never commit `.env`). `docker-compose.yml` reads these via
# `${VAR:-default}` interpolation — every value below already has a
# non-secret local-only default baked into the compose file, so `.env` is
# optional for a first `docker-compose up --build`.
#
# These are LOCAL DEV CREDENTIALS ONLY for containers bound to your own
# machine (Postgres/Redis/MinIO/Mailpit, all published on 127.0.0.1). They
# are never used in staging/production — T40 wires real secrets via the
# deploy platform.

POSTGRES_USER=chatspace
POSTGRES_PASSWORD=chatspace
POSTGRES_DB=chatspace

LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173

JWT_SIGNING_KEY=local-dev-only-signing-key-not-for-prod

SMTP_USERNAME=chatspace
SMTP_PASSWORD=local-dev-only-smtp-password
SMTP_FROM_ADDRESS=no-reply@chatspace.example

PASSWORD_RESET_URL_BASE=http://localhost:5173/reset-password
INVITE_URL_BASE=http://localhost:5173/accept-invite

MINIO_ROOT_USER=chatspace
MINIO_ROOT_PASSWORD=chatspace-minio
S3_BUCKET_NAME=chatspace-media

BOOTSTRAP_ADMIN_EMAIL=admin@chatspace.example
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=local-dev-only-admin-pw1
BOOTSTRAP_ADMIN_FIRST_NAME=System
BOOTSTRAP_ADMIN_LAST_NAME=Admin

VITE_API_BASE_URL=http://localhost:8000/v1
