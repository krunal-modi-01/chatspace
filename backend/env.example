# Copy to `.env` for local development (never commit `.env` with real values).
# CLAUDE.md secrets_location: env vars only. Values below are placeholders,
# not defaults — Settings has no hardcoded fallback for any of these.

APP_ENV=development
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql+asyncpg://chatspace:chatspace@localhost:5432/chatspace
# Per-instance asyncpg pool + bounded statement timeout (technical spec:
# "fast errors rather than hanging" when Postgres is down/slow). Defaults
# below are the `Settings` field defaults; override per-environment.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=5.0
DB_STATEMENT_TIMEOUT_MS=5000
DB_CONNECT_TIMEOUT_SECONDS=3.0

REDIS_URL=redis://localhost:6379/0

JWT_SIGNING_KEY=replace-with-a-long-random-value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=chatspace
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_ADDRESS=no-reply@chatspace.example
SMTP_USE_TLS=false

S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=chatspace-media
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_REGION=auto

BOOTSTRAP_ADMIN_EMAIL=admin@chatspace.example
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
# Must satisfy the password policy (>= 6 chars, at least one letter and
# one digit) — bootstrap fails loudly at startup otherwise (ADR-0009).
BOOTSTRAP_ADMIN_FIRST_NAME=replace-with-first-name
BOOTSTRAP_ADMIN_LAST_NAME=replace-with-last-name

# T39 Observability: Sentry-class error/uptime monitor, config-driven and
# OFF by default (leave unset locally). Requires the optional 'sentry-sdk'
# dependency (`uv sync --extra observability`) to actually report; see
# app.core.error_monitor for the no-op-if-missing fallback.
# ERROR_MONITOR_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# ERROR_MONITOR_TRACES_SAMPLE_RATE=0.0
